{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "retailiq/school_district_signal",
  "title": "School District & Family Quality Signal",
  "description": "Layer 2 stub — normalized school district data. Wire in your NCES or GreatSchools API here.",
  "type": "object",
  "required": ["lat", "lng", "district_name"],
  "properties": {
    "lat": { "type": "number" },
    "lng": { "type": "number" },
    "district_name": { "type": "string" },
    "district_id": { "type": "string", "description": "NCES district LEAID" },
    "overall_rating": { "type": "number", "minimum": 1, "maximum": 10 },
    "test_score_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Student proficiency percentile vs state average"
    },
    "student_teacher_ratio": { "type": "number" },
    "schools_within_3_miles": { "type": "integer" },
    "elementary_rating": { "type": "number", "minimum": 1, "maximum": 10 },
    "middle_rating": { "type": "number", "minimum": 1, "maximum": 10 },
    "high_rating": { "type": "number", "minimum": 1, "maximum": 10 },
    "free_lunch_pct": { "type": "number", "description": "% students on free/reduced lunch (inverse income proxy)" },
    "family_quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Composite 0-100 combining school quality + demographics"
    }
  },
  "_tinyfish_note": "TinyFish can scrape GreatSchools.org, NCES Common Core of Data, or Niche.com school district pages."
}
