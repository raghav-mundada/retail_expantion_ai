# ── Secrets & API Keys ───────────────────────────────────────────────────────
# NEVER commit credentials — add any secret file pattern here
.env
.env.*
*.env
.env.local
.env.development
.env.production
secrets.yaml
secrets.json
secrets.toml
config/secrets.*
census_api_key.txt
api_keys.*
*_api_key*
*_secret*
*credentials*
*.pem
*.key

# ── Data outputs (large, reproducible by running the pipeline) ───────────────
data/processed/
data/raw/
aadt_data/

# Preserve folder structure without committing data files
!data/.gitkeep
!data/processed/.gitkeep
!data/raw/.gitkeep

# Spatial / GIS source files
*.shp
*.dbf
*.shx
*.prj
*.cpg
*.zip

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing / Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
