# ── Data files ──────────────────────────────────────────────────────────────
# Processed outputs (large, reproducible via pipelines)
data/processed/
data/raw/
aadt_data/

# Keep directory structure but not the files
!data/.gitkeep
!data/processed/.gitkeep
!data/raw/.gitkeep

# Spatial / GIS raw files
*.shp
*.dbf
*.shx
*.prj
*.cpg
*.zip

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.yaml
secrets.json
census_api_key.txt

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing / Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
